{
  "name": "Intelligent Return System",
  "nodes": [
    {
      "id": "node_1",
      "type": "Webhook",
      "name": "Trigger",
      "config": {
        "accepted_inputs": [
          "order_id",
          "customer_name",
          "email",
          "return_reason"
        ]
      },
      "next": "node_2"
    },
    {
      "id": "node_2",
      "type": "Function",
      "name": "Processing",
      "config": {
        "description": "Cleans whitespace from 'order_id' and adds a timestamp.",
        "code": "return { ...inputs, order_id: inputs.order_id.trim(), timestamp: new Date().toISOString() };"
      },
      "next": "node_3"
    },
    {
      "id": "node_3",
      "type": "AI Completion",
      "name": "AI Integration",
      "config": {
        "task": "Analyze the 'return_reason'. Determine category and urgency level (High, Medium, Low).",
        "rules": [
          {
            "condition": "Mentions damage/broken",
            "category": "Shipping Damage",
            "urgency": "High"
          },
          {
            "condition": "Mentions size/fit",
            "category": "Exchange",
            "urgency": "Medium"
          }
        ],
        "outputs": [
          "category",
          "urgency"
        ]
      },
      "next": "node_4"
    },
    {
      "id": "node_4",
      "type": "Google Sheets",
      "name": "Export",
      "config": {
        "spreadsheet_id": "1JQ-AYlhu2nNz26-7w1Oa5qKyoP7V3SiVcbUegvughdE",
        "action": "append",
        "mapping": {
          "Timestamp": "timestamp",
          "Customer Name": "customer_name",
          "Email": "email",
          "Message": "return_reason",
          "AI Category": "category",
          "Urgency Level": "urgency"
        }
      },
      "next": null
    }
  ]
}
